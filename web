!DOCTYPE html>
<html lang="tr">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>💎 Kristal Snake</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{

background:linear-gradient(180deg,#040816,#071d3f,#091329);
color:white;
overflow-x:hidden;

}

/* Arka Plan Yıldızları */

.stars{

position:fixed;
width:100%;
height:100%;
top:0;
left:0;
pointer-events:none;

}

.star{

position:absolute;
width:3px;
height:3px;
background:white;
border-radius:50%;
animation:twinkle 2s infinite;

}

@keyframes twinkle{

50%{
opacity:.2;
transform:scale(1.8);
}

}

/* Başlık */

header{

text-align:center;
padding:100px 20px;

}

h1{

font-size:72px;
color:#00ffff;
text-shadow:0 0 25px cyan;
animation:float 3s infinite;

}

@keyframes float{

50%{
transform:translateY(-12px);
}

}

.subtitle{

font-size:24px;
margin-top:20px;
color:#b9e8ff;

}

/* Buton */

.play{

margin-top:45px;
padding:18px 45px;
font-size:24px;
border:none;
border-radius:16px;
background:#00aaff;
color:white;
cursor:pointer;
transition:.3s;
box-shadow:0 0 25px #00aaff;

}

.play:hover{

transform:scale(1.1);
box-shadow:0 0 40px cyan;

}

/* Kartlar */

.cards{

display:flex;
justify-content:center;
gap:25px;
flex-wrap:wrap;
padding:80px 20px;

}

.card{

width:260px;
background:#0b1735;
padding:20px;
border-radius:18px;
border:2px solid cyan;
transition:.3s;

}
